{
  "name": "room-tablet-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:migrate": "DATABASE_URL=${DATABASE_ADMIN_URL:-$DATABASE_URL} prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "DATABASE_URL=${DATABASE_ADMIN_URL:-$DATABASE_URL} prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.6.1",
    "prisma": "^7.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
